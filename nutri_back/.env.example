# 阿里云百炼 Qwen 密钥：仅填写在本地 nutri_back/.env，切勿提交到 Git。
DASHSCOPE_API_KEY=请替换为你的百炼_API_Key

# 可选：模型权重的绝对路径；不填时使用 nutri_back/classify_model/weight/best_checkpoint.pth。
MODEL_CHECKPOINT_PATH=/opt/nutriscreen/models/best_checkpoint.pth

# 可选：默认 qwen-plus；可根据已开通的百炼模型调整。
QWEN_MODEL=qwen-plus

# 可选：北京默认地址。若使用工作空间专属域名，请替换为实际地址。
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 可选：请求超时秒数；个性化建议是结构化生成，建议至少 90 秒。
QWEN_TIMEOUT_SECONDS=90
